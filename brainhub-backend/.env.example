# Configuración de la aplicación BrainHub Backend
# Cambiar valores según tu entorno

# ═══════════════════════════════════════════════════
# POSTGRESQL
# ═══════════════════════════════════════════════════

POSTGRES_USER=brainhub_user
POSTGRES_PASSWORD=CAMBIAR_POR_CONTRASEÑA_SEGURA
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=brainhub_db

# ═══════════════════════════════════════════════════
# JWT & SEGURIDAD
# ═══════════════════════════════════════════════════

SECRET_KEY=CAMBIAR_POR_CLAVE_SECRETA_FUERTE_MIN_32_CARACTERES
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ═══════════════════════════════════════════════════
# API ANTHROPIC (Claude)
# ═══════════════════════════════════════════════════

ANTHROPIC_API_KEY=tu_clave_api_anthropic_aqui

# ═══════════════════════════════════════════════════
# APLICACIÓN
# ═══════════════════════════════════════════════════

APP_NAME=BrainHub Studio Backend
APP_VERSION=1.0.0
DEBUG=False
ENVIRONMENT=production

# ═══════════════════════════════════════════════════
# CORS (URLs permitidas)
# ═══════════════════════════════════════════════════

CORS_ORIGINS=["https://brainhub.example.com", "https://www.brainhub.example.com"]
CORS_CREDENTIALS=True
CORS_METHODS=["*"]
CORS_HEADERS=["*"]
